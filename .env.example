# World Cup Goal Predictor Environment Configuration
# Copy this file to '.env' and modify the values for your setup.

# Database URL for SQLAlchemy (e.g., SQLite, PostgreSQL)
DATABASE_URL=sqlite:///./predictor.db

# Secret key for JWT token generation and authentication signing.
# Change this to a secure random string in production!
SECRET_KEY=super_secret_world_cup_predictor_key_change_me_in_production_987654321
